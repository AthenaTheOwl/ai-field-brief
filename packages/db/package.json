{
  "name": "@aifieldbrief/db",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "description": "Drizzle schema, Neon client, and tenant-scoped query helpers for AI Field Brief. Every workspace-scoped query takes workspaceId; helpers throw if it is missing.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./queries": "./src/queries/index.ts"
  },
  "files": [
    "src",
    "drizzle",
    "README.md"
  ],
  "scripts": {
    "lint": "echo \"@aifieldbrief/db: lint placeholder\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "build": "echo \"@aifieldbrief/db: source-only package, no build step\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@aifieldbrief/sources": "workspace:*",
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.36.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
