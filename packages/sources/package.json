{
  "name": "@aifieldbrief/sources",
  "version": "0.0.2",
  "private": true,
  "license": "Apache-2.0",
  "description": "Canonical source-item contract, transcripts, citations, provenance. Phase 2 lands the connector contract + 4 full connectors (rss, podcast-rss, article-url, github-releases) + 14 stubs for the remaining source types.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./ops": "./src/ops.ts",
    "./schemas/source-item": "./schemas/source-item.schema.json",
    "./schemas/transcript": "./schemas/transcript.schema.json",
    "./schemas/citation": "./schemas/citation.schema.json",
    "./schemas/provenance": "./schemas/provenance.schema.json"
  },
  "files": [
    "schemas",
    "src",
    "README.md"
  ],
  "scripts": {
    "lint": "echo \"@aifieldbrief/sources: lint placeholder\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "build": "echo \"@aifieldbrief/sources: source-only package, no build step\""
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
