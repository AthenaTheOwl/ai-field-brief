{
  "name": "@aifieldbrief/web",
  "version": "0.0.2",
  "private": true,
  "license": "Apache-2.0",
  "description": "AI Field Brief web app (Next.js 15 App Router). Phase 1 scaffold + public brief renderer at /briefs.",
  "type": "module",
  "scripts": {
    "predev": "node scripts/snapshot-briefs.mjs",
    "dev": "next dev --port 3000",
    "prebuild": "node scripts/snapshot-briefs.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "echo \"@aifieldbrief/web: lint placeholder\"",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/snapshot-briefs.mjs",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@aifieldbrief/db": "workspace:*",
    "@aifieldbrief/sources": "workspace:*",
    "@clerk/nextjs": "^6.9.6",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "next": "^15.2.3",
    "react": "~19.2.6",
    "react-dom": "~19.0.3",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^15.11.7",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
