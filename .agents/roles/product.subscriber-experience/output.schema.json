{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProductSubscriberExperienceOutput",
  "description": "Output shape for product.subscriber-experience runs: the journey review plus any comprehension findings.",
  "type": "object",
  "required": ["week", "review_path", "scenarios"],
  "additionalProperties": false,
  "properties": {
    "week": {
      "type": "string",
      "pattern": "^\\d{4}-W\\d{2}$",
      "description": "ISO week of the brief under review, e.g. 2026-W21."
    },
    "review_path": {
      "type": "string",
      "description": "Repo-relative path to the journey review under reports/subscriber/."
    },
    "scenarios": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["name", "first_60s", "by_minute_3", "by_minute_10"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "enum": ["cold_landing_index", "cold_landing_brief", "return_visitor"]
          },
          "first_60s": {"type": "string"},
          "by_minute_3": {"type": "string"},
          "by_minute_10": {"type": "string"}
        }
      }
    },
    "comprehension_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["paragraph", "gap", "proposed_edit"],
        "additionalProperties": false,
        "properties": {
          "paragraph": {"type": "string"},
          "gap": {
            "type": "string",
            "enum": ["jargon", "missing_context", "unstated_assumption", "voice_drift", "no_move_named"]
          },
          "proposed_edit": {"type": "string"}
        }
      }
    }
  }
}
