{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScienceCellVerifierOutput",
  "description": "Output shape for science.cell-verifier runs: one verdict per cell with a root-cause read on every non-pass.",
  "type": "object",
  "required": ["matrix_run_id", "verdicts"],
  "additionalProperties": false,
  "properties": {
    "matrix_run_id": {
      "type": "string"
    },
    "verdicts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["cell_id", "verdict"],
        "additionalProperties": false,
        "properties": {
          "cell_id": {"type": "string"},
          "verdict": {
            "type": "string",
            "enum": ["PASS", "PATCH_CELL", "FAIL_CELL"]
          },
          "root_cause": {
            "type": "string",
            "description": "One-line read of the failure: rule, source span, suggested patch."
          },
          "patch_instruction": {
            "type": "string"
          }
        }
      }
    }
  }
}
