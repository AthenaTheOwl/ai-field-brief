{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScienceLensDesignerOutput",
  "description": "Output shape for science.lens-designer runs: the ordered lens selection plus optional lens candidate.",
  "type": "object",
  "required": ["profile_id", "lens_selection"],
  "additionalProperties": false,
  "properties": {
    "profile_id": {
      "type": "string",
      "description": "Brief profile the selection applies to."
    },
    "lens_selection": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["lens_id", "required"],
        "additionalProperties": false,
        "properties": {
          "lens_id": {"type": "string"},
          "required": {"type": "boolean"},
          "profile_guard": {"type": "string"},
          "guard_outcome": {
            "type": "string",
            "enum": ["allow", "drop"]
          }
        }
      }
    },
    "lens_candidate": {
      "type": "object",
      "description": "Optional draft of a new lens entry. Lands as a prompt_patch for human review.",
      "additionalProperties": true
    }
  }
}
