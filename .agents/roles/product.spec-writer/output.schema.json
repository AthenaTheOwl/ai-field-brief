{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProductSpecWriterOutput",
  "description": "Output shape for product.spec-writer runs: the new or updated spec ledger and the traceability rows.",
  "type": "object",
  "required": ["spec_id", "files_written", "requirements"],
  "additionalProperties": false,
  "properties": {
    "spec_id": {
      "type": "string",
      "pattern": "^\\d{4}-[a-z0-9][a-z0-9-]*$",
      "description": "Spec folder name under specs/."
    },
    "files_written": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "description": "Repo-relative path of a file the run wrote."
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "owner_role"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^R-[A-Z]+-\\d{3,}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "owner_role": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_-]*$"
          },
          "dec_planned": {
            "type": "string",
            "description": "Filename of the DEC the spec-writer plans (or has filed) for this requirement."
          }
        }
      }
    }
  }
}
