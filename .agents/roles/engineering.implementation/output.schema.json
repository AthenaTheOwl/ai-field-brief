{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EngineeringImplementationOutput",
  "description": "Output shape for engineering.implementation runs: the patch summary and the test report.",
  "type": "object",
  "required": ["requirement_id", "files_changed", "test_report"],
  "additionalProperties": false,
  "properties": {
    "requirement_id": {
      "type": "string",
      "pattern": "^R-[A-Z]+-\\d{3,}$"
    },
    "files_changed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "change_type"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "description": "Repo-relative path of the changed file."
          },
          "change_type": {
            "type": "string",
            "enum": ["added", "modified", "renamed", "deleted"]
          },
          "lines_added": {
            "type": "integer",
            "minimum": 0
          },
          "lines_removed": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "test_report": {
      "type": "object",
      "required": ["suites_run", "passed", "failed"],
      "additionalProperties": false,
      "properties": {
        "suites_run": {
          "type": "array",
          "items": {"type": "string"}
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
