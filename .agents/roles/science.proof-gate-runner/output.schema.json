{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScienceProofGateRunnerOutput",
  "description": "Output shape for science.proof-gate-runner runs: per-gate results plus a top-level verdict.",
  "type": "object",
  "required": ["verdict", "gates"],
  "additionalProperties": false,
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["green", "blocking"]
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status", "exit_code"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "crashed", "skipped"]
          },
          "exit_code": {"type": "integer"},
          "duration_ms": {"type": "integer", "minimum": 0},
          "files_scanned": {"type": "integer", "minimum": 0},
          "first_output_lines": {
            "type": "array",
            "items": {"type": "string"},
            "maxItems": 10
          },
          "root_cause": {
            "type": "string",
            "description": "One-line read of the failure: rule, file, line, suggested fix."
          }
        }
      }
    }
  }
}
